# DataFlow - Production Environment Configuration
# Copy this file to .env and fill in the values

# PostgreSQL connection string (required)
# Use a managed PostgreSQL service (e.g., Neon, Supabase, AWS RDS, Render)
DATABASE_URL=postgresql://user:password@host:5432/dataflow?sslmode=require

# SSL for database connection (default: true with rejectUnauthorized=false)
# Set to false only if your database does not support SSL
# DB_SSL=false

# Server port (default: 5000)
PORT=5000

# CORS origin (default: * allows all origins)
# Set to your domain in production for security
CORS_ORIGIN=https://your-domain.com

# Logging level: debug, info, warn, error (default: warn in production)
LOG_LEVEL=warn

# Enable request logging (default: false in production)
LOG_REQUESTS=false

# Mock auth user (used when auth is disabled)
AUTH_USER_EMAIL=admin@dataflow.app
AUTH_USER_NAME=Admin
AUTH_USER_ROLE=admin

# Node.js environment (set automatically by npm start script)
# NODE_ENV=production
