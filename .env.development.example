# DataFlow - Development Environment Configuration
# Copy this file to .env and fill in the values

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/dataflow

# Disable SSL for local PostgreSQL (set to false for local dev without SSL)
DB_SSL=false

# Server port (default: 5000)
PORT=5000

# Logging level: debug, info, warn, error (default: debug)
LOG_LEVEL=debug

# Mock auth user (used when auth is disabled)
AUTH_USER_EMAIL=user@local
AUTH_USER_NAME=Local User
AUTH_USER_ROLE=admin
